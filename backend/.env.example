# Required — OpenAI embeddings (search / seed / StageLync)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional OpenAI chat failover
OPENAI_CHAT_MODEL=gpt-4o-mini

# Required for chat POC — Groq free Llama Instruct 70B
# https://console.groq.com → API keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Optional — xAI / Grok (extra failover only)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_CHAT_MODEL=grok-4.3

# POC routing: all chat → Groq; embed stays OpenAI
AI_CHEAP_PROVIDER=groq
AI_QUALITY_PROVIDER=groq
AI_FALLBACK=true

# Local SQLite (no Docker) — file: backend/olc.db
DATABASE_URL=sqlite:///./olc.db
